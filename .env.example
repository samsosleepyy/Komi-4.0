PYTHON_VERSION=3.12.8
# ห้ามใส่ token/webhook จริงลง Git หรือส่งให้คนอื่น
DISCORD_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
WEBHOOK_URL=PUT_YOUR_DISCORD_WEBHOOK_URL_HERE
ALLOWED_GUILDS=1420339720277463112,1441795602550882334
MAX_PARALLEL_JOBS=1

# ปกติบอทไม่ต้องใช้ Server Members Intent; เปิดเฉพาะถ้าคุณเพิ่มฟีเจอร์ที่ต้องอ่าน member list จริง ๆ
ENABLE_MEMBER_INTENT=0

# จำกัดขนาดไฟล์ที่ user อัปโหลดและขนาด zip หลังแตก เพื่อลดปัญหา zip bomb / disk เต็ม
MAX_UPLOAD_BYTES=26214400
MAX_MERGE_TOTAL_UPLOAD_BYTES=78643200
DISCORD_UPLOAD_LIMIT_BYTES=26214400
MAX_ZIP_MEMBERS=2000
MAX_ZIP_UNCOMPRESSED_BYTES=157286400
MAX_ZIP_SINGLE_FILE_BYTES=52428800
MAX_ZIP_MEMBER_NAME_LENGTH=240

# อายุ ticket channel: ก่อนอัปโหลด / ระหว่างรอกดปุ่ม / หลังทำงานเสร็จ
INITIAL_TICKET_TTL=180
ACTIVE_TICKET_TTL=900
FINISHED_TICKET_TTL=60
# ระหว่างที่บอทกำลัง convert/merge อยู่ จะใช้ค่านี้เพื่อกันไม่ให้ ticket ถูกลบกลางงาน
PROCESSING_TICKET_TTL=3600
STALE_TICKET_CLEANUP_MINUTES=30

# เหมาะกับ Render ฟรี: ลดการ edit message ถี่เกินไป และลบ temp เก่าตอนเปิดบอท
PROGRESS_UPDATE_INTERVAL=10
TEMP_MAX_AGE_HOURS=6
